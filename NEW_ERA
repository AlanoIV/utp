                                            end
                                        end
                                    end
                                    task.wait(autoMineDelay)
                                    continue
                                else
                                    local bv = root and root:FindFirstChild("AutoMineFloat")
                                    if bv then bv:Destroy() end
                                end
                            end
                        end
                        task.wait(0.03)
                    end
                    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if root then
                        local bv = root:FindFirstChild("AutoMineFloat")
                        if bv then bv:Destroy() end
