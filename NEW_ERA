                    end
                    while autoMineEnabled do
                        -- Make sure LocalPlayer exists
                        if not LocalPlayer then
                            task.wait(0.1)
                            continue
                        end
                        
                        local Character = LocalPlayer.Character
                        if not Character then
                            task.wait(0.1)
                            continue
                        end
                        
                        local Tool = GetTool()
                        if not Tool then
                            task.wait(0.1)
                            continue
                        end
                        local isPickaxe = string.lower(Tool.Name):find("pickaxe") ~= nil
                        if Tool.Parent == LocalPlayer.InnoBackpack and not isPickaxe then
                            local equipRemote = Tool:FindFirstChild("EquipRemote")
                            if equipRemote then
                                equipRemote:FireServer(true)
                                task.wait(0.2)
                            end
                        end
                        if (Tool.Parent == LocalPlayer.Character) or (Tool.Parent == LocalPlayer.InnoBackpack and isPickaxe) then
                            local root = Character and Character:FindFirstChild("HumanoidRootPart")
                            if root then
                                if _G.CurrentMineTarget and (not _G.CurrentMineTarget.Parent or not _G.CurrentMineTarget:IsDescendantOf(workspace)) then
                                    _G.CurrentMineTarget = nil
                                end
                                
                                if not _G.CurrentMineTarget then
                                    local closestBlock, closestDist = nil, math.huge
                                    local closestDirt, closestDirtDist = nil, math.huge
                                    
                                    _G.MineBlacklist = _G.MineBlacklist or {}
                                    
                                    local function checkOre(v)
                                        if v:IsA("MeshPart") or v:IsA("Part") or v:IsA("BasePart") then
                                            -- Ignore huge architectural parts and character limbs
                                            if v.Size.X > 25 or v.Size.Y > 25 or v.Size.Z > 25 then return end
                                            if v.Parent and v.Parent:FindFirstChild("Humanoid") then return end
                                            if table.find(_G.MineBlacklist, v) then return end
                                            
                                            local mineId = _G.ExtractOreName(v)
                                            
                                            local dist = (root.Position - v.Position).Magnitude
                                            local isOre = (mineId and mineId ~= "Unknown" and mineId ~= "Part" and mineId ~= "MeshPart" and mineId ~= "OreMesh" and string.lower(tostring(mineId)) ~= "stone")
                                            
                                            if isOre and not table.find(OreIgnoreList, mineId) then
                                                -- Ores must respect the Auto Mine Range slider limit
                                                if dist <= autoMineRange and dist < closestDist then
                                                    closestBlock = v
                                                    closestDist = dist
                                                end
                                            end
                                        end
                                    end
                                    
                                    -- Check classic folders for valuable ores
                                    local placedOre = workspace:FindFirstChild("PlacedOre")
                                    local spawnedBlocks = workspace:FindFirstChild("SpawnedBlocks")
                                    if placedOre then for _,v in pairs(placedOre:GetChildren()) do checkOre(v) end end
                                    if spawnedBlocks then for _,v in pairs(spawnedBlocks:GetChildren()) do checkOre(v) end end
                                    
                                    -- Deep Tunneling / Edge Clearing Logic (Physical scan avoids decorators)
                                    if autoMineDirtFallback and not closestBlock then
                                        local deepestProgression = -math.huge
                                        local overlapParams = OverlapParams.new()
                                        local nearbyParts = workspace:GetPartBoundsInRadius(root.Position, 60, overlapParams)
                                        for _, v in pairs(nearbyParts) do
                                            if v:IsA("Part") and math.round(v.Size.X) == 4 and math.round(v.Size.Y) == 4 and math.round(v.Size.Z) == 4 and v.Name ~= "HumanoidRootPart" then
                                                if not v.Parent:FindFirstChild("Humanoid") and not table.find(_G.MineBlacklist, v) then
                                                    local pId = _G.ExtractOreName(v)
                                                    if type(pId) == "string" and (string.lower(pId) == "obsidian" or table.find(OreIgnoreList, pId)) then continue end
                                                    
                                                    local pos = v.Position
                                                    local prog = 0
                                                    local limitExceeded = false
                                                    
                                                    if autoMineDigDir == "-Y (Down)" then
                                                        prog = -pos.Y
                                                        if pos.Y <= -autoMineDepthLimit then limitExceeded = true end
                                                    elseif autoMineDigDir == "+Y (Up)" then
                                                        prog = pos.Y
                                                        if pos.Y >= autoMineDepthLimit then limitExceeded = true end
                                                    elseif autoMineDigDir == "-Z (Forward)" then
                                                        prog = -pos.Z
                                                        if pos.Z <= -autoMineDepthLimit then limitExceeded = true end
                                                    elseif autoMineDigDir == "+Z (Backward)" then
                                                        prog = pos.Z
                                                        if pos.Z >= autoMineDepthLimit then limitExceeded = true end
                                                    elseif autoMineDigDir == "+X (Right)" then
                                                        prog = pos.X
                                                        if pos.X >= autoMineDepthLimit then limitExceeded = true end
                                                    elseif autoMineDigDir == "-X (Left)" then
                                                        prog = -pos.X
                                                        if pos.X <= -autoMineDepthLimit then limitExceeded = true end
                                                    end
                                                    
                                                    if (not limitExceeded) and (prog > deepestProgression) then
                                                        deepestProgression = prog
                                                        closestDirt = v
                                                    end
                                                end
                                            end
                                        end
                                    end
                                    
                                    if closestBlock then
                                        _G.OreEmptyTick = nil
                                        _G.CurrentMineTarget = closestBlock
                                    else
                                        _G.OreEmptyTick = _G.OreEmptyTick or tick()
                                        if autoMineDirtFallback and closestDirt and (tick() - _G.OreEmptyTick >= 3) then
                                            _G.CurrentMineTarget = closestDirt
                                        else
                                            _G.CurrentMineTarget = nil
                                        end
                                    end
                                    _G.MineAttempts = 0
                                end
                                
                                local targetBlock = _G.CurrentMineTarget
                                
                                if targetBlock then
                                    -- Pause mining if our bag is full (prevent wasteful spam and false blacklisting)
                                    local currentOres = 0
                                    local playerWorkspace = workspace:FindFirstChild(LocalPlayer.Name)
                                    if playerWorkspace then
                                        local orePackCargo = playerWorkspace:FindFirstChild("OrePackCargo")
                                        if orePackCargo then
                                            for _, child in pairs(orePackCargo:GetChildren()) do
                                                if not child:IsA("Weld") and not child:IsA("Motor6D") then
                                                    currentOres = currentOres + 1
                                                end
                                            end
                                        end
                                    end
                                    
                                    if currentOres >= (_G.AutoSellOreCount or 16) then
                                        task.wait(1)
                                        continue
                                    end
                                    
                                    _G.MineAttempts = (_G.MineAttempts or 0) + 1
                                    
                                    -- Prevent getting stuck on an unmineable block (8 attempts = ~10s)
                                    if _G.MineAttempts > 8 then
                                        _G.MineBlacklist = _G.MineBlacklist or {}
                                        table.insert(_G.MineBlacklist, targetBlock)
                                        _G.CurrentMineTarget = nil
                                        continue
                                    end
                                    
                                    if autoMineWarp then
                                        -- Use BodyVelocity to float gracefully
                                        local bv = root:FindFirstChild("AutoMineFloat")
                                        if not bv then
                                            bv = Instance.new("BodyVelocity")
                                            bv.Name = "AutoMineFloat"
                                            bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                                            bv.Velocity = Vector3.new(0, 0, 0)
                                            bv.Parent = root
                                        end
                                        
                                        -- Noclip: prevent hitting ores/walls
                                        if not _G.AutoMineNoclipConnection then
                                            _G.AutoMineNoclipConnection = game:GetService("RunService").Stepped:Connect(function()
