            if part.Name ~= "Part" and part.Name ~= "MeshPart" and part.Name ~= "OreMesh" then return part.Name end
            
            local parent = part.Parent
            if parent and parent ~= workspace and parent.Name ~= "PlacedOre" and parent.Name ~= "SpawnedBlocks" and parent.Name ~= "Workspace" then
                return parent.Name
            end
            
            for _, child in pairs(part:GetDescendants()) do
                if child:IsA("StringValue") and (string.find(string.lower(child.Name), "name") or string.find(string.lower(child.Name), "id")) then
                    return child.Value
                end
                if child:IsA("TextLabel") and child.Text and child.Text ~= "" and child.Text ~= "Label" then
